{
  "name": "@meridian/markup",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/markup",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/markup",
        "command": "pnpm run build"
      },
      "inputs": ["default", "^default"],
      "cache": true
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/markup",
        "command": "tsc --noEmit -p tsconfig.json"
      },
      "inputs": ["default", "^default"],
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/markup",
        "command": "vitest run --passWithNoTests"
      },
      "inputs": ["default", "^default"],
      "cache": true
    }
  }
}
