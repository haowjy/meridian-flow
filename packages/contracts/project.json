{
  "name": "@meridian/contracts",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/contracts/src",
  "projectType": "library",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/contracts",
        "command": "tsc --noEmit -p tsconfig.json"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/contracts",
        "command": "vitest run"
      }
    }
  }
}
