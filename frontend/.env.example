# === LOCAL DEVELOPMENT (recommended) ===
# Run ./scripts/dev/supabase-start.sh to auto-generate frontend/.env.local with these values.
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_PUBLISHABLE_KEY=<anon key from supabase status>

# === CLOUD SUPABASE ===
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Backend API URL
VITE_API_URL=http://localhost:8080  # Development
# VITE_API_URL=https://your-backend.railway.app  # Production (set in Vercel)

VITE_DEV_TOOLS=0
