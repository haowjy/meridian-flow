{
  "name": "meridian",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "bootstrap": "tsx tools/dev/bootstrap.ts",
    "db:migrate": "pnpm --filter @meridian/database db:migrate",
    "db:generate": "pnpm --filter @meridian/database db:generate",
    "db:apply-functions": "pnpm --filter @meridian/database db:apply-functions",
    "db:studio": "pnpm --filter @meridian/database db:studio",
    "dev": "tsx tools/dev/dev-tmux.ts",
    "dev:restart": "tsx tools/dev/dev-tmux.ts --restart --preserve-mode",
    "dev:infra": "supabase start",
    "dev:infra:down": "supabase stop",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:env": "tsx tools/dev/supabase-env.ts",
    "supabase:reset": "supabase db reset",
    "lint": "biome check .",
    "format": "biome check .",
    "format:write": "biome check --write .",
    "typecheck": "node tools/ci/run-nx-target.mjs typecheck",
    "test": "vitest run --passWithNoTests",
    "check": "pnpm lint && pnpm check:negative-space && pnpm typecheck && pnpm test && pnpm check:graph",
    "portless:trust": "portless trust",
    "portless:list": "portless list",
    "prepare": "lefthook install",
    "dev:tmux": "tsx tools/dev/dev-tmux.ts",
    "dev:tailscale": "tsx tools/dev/dev-tmux.ts --tailscale",
    "dev:funnel": "tsx tools/dev/dev-tmux.ts --funnel",
    "check:graph": "node tools/ci/check-graph.mjs",
    "check:negative-space": "bash tools/ci/check-negative-space.sh"
  },
  "devDependencies": {
    "@meridian/database": "workspace:*",
    "@biomejs/biome": "^2.4.15",
    "drizzle-orm": "catalog:",
    "@types/node": "catalog:",
    "postgres": "catalog:",
    "lefthook": "^2.1.8",
    "nx": "^22.7.3",
    "portless": "^0.13.0",
    "tsx": "^4.22.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
