use mise

# Resolve the main checkout's root via git plumbing so linked worktrees inherit
# shared local secrets without copying them into every worktree.
_meridian_main_root() {
  local common_dir
  common_dir="$(git rev-parse --git-common-dir 2>/dev/null)" || return 1
  (cd "$common_dir/.." && pwd)
}

_main_env="$(_meridian_main_root)/.env"
watch_file "$_main_env"
dotenv_if_exists "$_main_env"

# Per-worktree overrides. Loaded before the database rewrite so the rewrite is
# the final authority on registered local DB URLs.
dotenv_if_exists .env.local

if ! _db_exports="$(pnpm exec tsx "$(git rev-parse --show-toplevel)/tools/dev/print-worktree-env.ts")"; then
  log_error "Failed to derive worktree database URLs (see errors above)"
  return 1
fi
eval "$_db_exports"
unset _db_exports
