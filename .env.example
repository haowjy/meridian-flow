# Copy to .env and set DATABASE_URL (see below). Start local Postgres with `pnpm dev:infra`.

# Drizzle / postgres.js — local postgres:16 container on host port 54422
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/meridian

# --- Dev test user (WorkOS Staging + bootstrap seed) ---
# WORKOS_DEV_LOGIN_EMAIL matches the Staging user; password only in gitignored .env.
WORKOS_DEV_LOGIN_EMAIL=test@meridian.dev
# WORKOS_DEV_LOGIN_PASSWORD=  # create user in WorkOS Staging or via API; do not commit
# WorkOS user id for the dev login (Staging dashboard → Users). Safe to copy here.
WORKOS_DEV_LOGIN_USER_ID=user_01KV3Q2WY6AATT6GSCQWWX2ZDM
# Internal Meridian user id seeded by `pnpm bootstrap` (printed after bootstrap).
TEST_USER_ID=
# --- App/server origin ---
# Required for production SSR API requests; dev resolves paired portless route automatically.
MERIDIAN_API_ORIGIN=

# --- Model providers (local dev defaults to mock) ---
# `pnpm dev` loads this file first. Parent-shell API keys are ignored unless you
# also set MODEL_PROVIDER to a real provider below (or export it in the shell).
# MODEL_PROVIDER=mock          # force in-process mock (deterministic e2e)
# MODEL_PROVIDER=auto            # use real keys from .env when present
# MODEL_PROVIDER=anthropic|openai
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# --- WorkOS AuthKit (@meridian/app) — use Staging in the WorkOS dashboard (free for dev). ---
# 1. Copy API key + Client ID from Staging → API Keys / AuthKit.
# 2. Cookie password: openssl rand -base64 32  (session sealing; not shown in dashboard).
# 3. Register every redirect URI you use in WorkOS Staging → Redirects, then set WORKOS_REDIRECT_URI
#    to your default (portless localhost). @meridian/app picks the request host in dev automatically.
#    - Local browser:  https://app.meridian.localhost/api/auth/callback  (tailscale/funnel named mode)
#      OR worktree-prefixed host from `pnpm portless:list` after plain `pnpm dev` (local mode)
#    - Tailscale remote: start `pnpm dev --tailscale`, then from `pnpm portless:list` copy the app row's
#      `tailscale:` URL and register https://<that-host>/api/auth/callback in WorkOS; sign in on that URL
#    - Do not use `portless get` for redirect URLs — it may not match registered routes (see DEVELOPMENT.md)
#    Dynamic redirect follows the request host only when scheme matches WORKOS_REDIRECT_URI
#    (https env + http://localhost:3000 will not switch — session cookies need a consistent Secure flag).
#    Use the same host for the whole sign-in flow (do not mix localhost and ts.net in one login).
# 4. Optional: create an Organization and add your user (B2B model; not required for solo dev).
# 5. Authentication → enable Sign up (easiest) or invite-only + invite your email.
# SSO/SCIM/production billing not needed for local dev sign-in.
WORKOS_API_KEY=sk_test_...
WORKOS_CLIENT_ID=client_...
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=https://app.meridian.localhost/api/auth/callback

# Dev-only: when set (e.g. =1), the app auto-logs-in the WORKOS_DEV_LOGIN_* user via
# /api/auth/dev-login instead of showing the WorkOS SSO screen. NODE_ENV!=production only.
# Set in gitignored .env for local automation; never enable in production.
# WORKOS_DEV_AUTOLOGIN=1
