# Copy to .env and set DATABASE_URL (see below). Start local Postgres with `pnpm dev:infra`.

# Drizzle / postgres.js — local postgres:16 container on host port 54422
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/meridian

# --- Database test fixture ---
# Internal Meridian user id for DB-backed integration tests. Use a throwaway DB.
TEST_USER_ID=
# --- App/server origin ---
# Required for production SSR API requests; dev resolves paired portless route automatically.
MERIDIAN_API_ORIGIN=

# --- Model providers (local dev defaults to mock) ---
# `pnpm dev` loads this file first. Parent-shell API keys are ignored unless you
# also set MODEL_PROVIDER to a real provider below (or export it in the shell).
# MODEL_PROVIDER=mock          # force in-process mock (deterministic e2e)
# MODEL_PROVIDER=auto            # use real keys from .env when present
# MODEL_PROVIDER=anthropic|openai
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=

# --- WorkOS AuthKit (@meridian/app) — use Staging in the WorkOS dashboard (free for dev). ---
# Copy API key + Client ID from Staging → API Keys / AuthKit.
# Cookie password: openssl rand -base64 32
# In dev the app auto-resolves the redirect host from the request origin (portless
# *.localhost, Tailscale *.ts.net). WORKOS_REDIRECT_URI just sets the scheme — leave
# the default https://app.meridian.localhost value; do NOT duplicate this line per worktree.
# Production uses WORKOS_REDIRECT_URI literally. Register it in WorkOS → Redirects.
WORKOS_API_KEY=sk_test_...
WORKOS_CLIENT_ID=client_...
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=https://app.meridian.localhost/api/auth/callback

# Dev-only: when set (e.g. =1), the app auto-logs-in the WORKOS_DEV_LOGIN_* user via
# /api/auth/dev-login instead of showing the WorkOS SSO screen. NODE_ENV!=production only.
# Set in gitignored .env for local automation; never enable in production.
# WORKOS_DEV_AUTOLOGIN=1
