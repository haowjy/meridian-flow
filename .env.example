# Copy to .env and fill from: pnpm supabase:env  (requires `pnpm supabase:start` first)
#
# Use the direct Postgres URL (port 54322) for Drizzle migrations — not the pooler.

# --- Supabase local (from `pnpm supabase:env` / `supabase status -o env`) ---
# Map: API_URL → SUPABASE_URL, ANON_KEY → SUPABASE_ANON_KEY, SERVICE_ROLE_KEY → SUPABASE_SERVICE_ROLE_KEY
SUPABASE_URL=http://127.0.0.1:54421
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Drizzle / postgres.js — direct DB connection (not the pooler)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54422/postgres

# --- Dev test user (created by `pnpm bootstrap`) ---
TEST_USER_EMAIL=test@meridian.dev
TEST_USER_PASSWORD=meridian-dev
# Set after bootstrap prints it, or leave empty to resolve by email
TEST_USER_ID=

# --- App/server origin ---
# Required for production SSR API requests; dev resolves paired portless route automatically.
MERIDIAN_API_ORIGIN=
