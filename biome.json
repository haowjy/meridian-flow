{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/.output",
      "!**/.nx",
      "!**/.mars",
      "!**/.meridian",
      "!**/.meridian-work",
      "!**/.codex-local",
      "!**/routeTree.gen.ts",
      "!apps/**/src/styles",
      "!packages/design-tokens/src/*.css",
      "!apps/app/.auth",
      "!apps/app/test-results",
      "!apps/app/playwright-report",
      "!.claude",
      "!.codex",
      "!.pi",
      "!.opencode",
      "!.cursor",
      "!**/.context",
      "!packages/agent-edit/demo/**/*.html",
      "!**/*.spike.test.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  }
}
