{
  "name": "@meridian/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit -p tsconfig.json",
    "start": "NODE_ENV=production node .output/server/index.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "auth:setup": "tsx e2e/auth.setup.ts",
    "test:e2e:auth": "playwright test -c e2e/playwright.auth.config.ts"
  },
  "dependencies": {
    "@meridian/contracts": "workspace:*",
    "@meridian/design-tokens": "workspace:*",
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-router": "^1.170.7",
    "@tanstack/react-start": "^1.168.10",
    "nitro": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
