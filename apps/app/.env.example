# @meridian/app loads environment from the repo root via direnv (see ../../.envrc).
# `pnpm bootstrap` creates ../../.env from ../../.env.example.
# Keep app-specific notes here; root .env remains the source of truth.
#
# Required for local Supabase auth/dev-login:
#   SUPABASE_URL
#   SUPABASE_ANON_KEY
#   TEST_USER_EMAIL
#   TEST_USER_PASSWORD
#
# Required for production SSR API requests:
#   MERIDIAN_API_ORIGIN
